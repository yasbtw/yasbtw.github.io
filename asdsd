<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Auto Sudoku Generator</title>

<style>
body {
  font-family: Arial, sans-serif;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #f5f5f5;
  margin: 0;
  padding: 20px;
}

h1 { margin-bottom: 10px; }

.controls {
  margin-bottom: 10px;
}

#grid {
  display: grid;
  grid-template-columns: repeat(9, 40px);
  grid-template-rows: repeat(9, 40px);
  border: 3px solid #333;
}

input {
  width: 40px;
  height: 40px;
  text-align: center;
  font-size: 18px;
  border: 1px solid #aaa;
}

input:disabled {
  background: #ddd;
  font-weight: bold;
}

input:nth-child(3n) {
  border-right: 2px solid #333;
}

input:nth-child(n+19):nth-child(-n+27),
input:nth-child(n+46):nth-child(-n+54) {
  border-bottom: 2px solid #333;
}

button, select {
  padding: 8px;
  margin: 5px;
  cursor: pointer;
}

.error {
  background: #ffb3b3;
}
</style>
</head>
<body>

<h1>Sudoku Generator</h1>

<div class="controls">
  <select id="difficulty">
    <option value="40">Easy</option>
    <option value="50" selected>Medium</option>
    <option value="60">Hard</option>
  </select>

  <button onclick="newGame()">New Game</button>
  <button onclick="check()">Check</button>
</div>

<div id="grid"></div>

<script>
let solution = [];
let puzzle = [];

const grid = document.getElementById("grid");

// ----------- GENERATE FULL VALID BOARD -----------
function generateFullBoard() {
  let board = Array.from({ length: 9 }, () => Array(9).fill(0));

  function isSafe(r, c, num) {
    for (let i = 0; i < 9; i++) {
      if (board[r][i] === num || board[i][c] === num) return false;
    }

    let sr = Math.floor(r / 3) * 3;
    let sc = Math.floor(c / 3) * 3;

    for (let i = 0; i < 3; i++) {
      for (let j = 0; j < 3; j++) {
        if (board[sr + i][sc + j] === num) return false;
      }
    }
    return true;
  }

  function fillCell(r, c) {
    if (r === 9) return true;
    if (c === 9) return fillCell(r + 1, 0);

    let nums = [1,2,3,4,5,6,7,8,9];
    nums.sort(() => Math.random() - 0.5);

    for (let num of nums) {
      if (isSafe(r, c, num)) {
        board[r][c] = num;
        if (fillCell(r, c + 1)) return true;
        board[r][c] = 0;
      }
    }

    return false;
  }

  fillCell(0, 0);
  return board;
}

// ----------- REMOVE CELLS TO MAKE PUZZLE -----------
function makePuzzle(board, removeCount) {
  let puzzle = board.map(row => [...row]);

  while (removeCount > 0) {
    let r = Math.floor(Math.random() * 9);
    let c = Math.floor(Math.random() * 9);

    if (puzzle[r][c] !== 0) {
      puzzle[r][c] = 0;
      removeCount--;
    }
  }

  return puzzle;
}

// ----------- RENDER GRID -----------
function render(board) {
  grid.innerHTML = "";

  for (let r = 0; r < 9; r++) {
    for (let c = 0; c < 9; c++) {
      const input = document.createElement("input");
      input.maxLength = 1;

      if (board[r][c] !== 0) {
        input.value = board[r][c];
        input.disabled = true;
      }

      input.dataset.r = r;
      input.dataset.c = c;

      input.oninput = (e) => {
        e.target.value = e.target.value.replace(/[^1-9]/g, "");
      };

      grid.appendChild(input);
    }
  }
}

// ----------- GET CURRENT BOARD -----------
function getBoard() {
  let inputs = document.querySelectorAll("input");
  let board = Array.from({ length: 9 }, () => Array(9).fill(0));

  inputs.forEach(inp => {
    let r = inp.dataset.r;
    let c = inp.dataset.c;
    board[r][c] = inp.value ? parseInt(inp.value) : 0;
  });

  return board;
}

// ----------- CHECK SOLUTION -----------
function check() {
  let current = getBoard();
  let ok = true;

  document.querySelectorAll("input").forEach(i => i.classList.remove("error"));

  for (let r = 0; r < 9; r++) {
    for (let c = 0; c < 9; c++) {
      let val = current[r][c];
      if (val === 0) continue;

      current[r][c] = 0;

      if (!isValid(current, r, c, val)) {
        mark(r, c);
        ok = false;
      }

      current[r][c] = val;
    }
  }

  alert(ok ? "Looks good 👍" : "Some errors found ❌");
}

function isValid(board, r, c, val) {
  for (let i = 0; i < 9; i++) {
    if (board[r][i] === val || board[i][c] === val) return false;
  }

  let sr = Math.floor(r / 3) * 3;
  let sc = Math.floor(c / 3) * 3;

  for (let i = 0; i < 3; i++) {
    for (let j = 0; j < 3; j++) {
      if (board[sr+i][sc+j] === val) return false;
    }
  }

  return true;
}

function mark(r, c) {
  document.querySelectorAll("input").forEach(inp => {
    if (inp.dataset.r == r && inp.dataset.c == c) {
      inp.classList.add("error");
    }
  });
}

// ----------- NEW GAME -----------
function newGame() {
  let difficulty = parseInt(document.getElementById("difficulty").value);

  solution = generateFullBoard();
  puzzle = makePuzzle(solution, difficulty);

  render(puzzle);
}

// start first game
newGame();
</script>

</body>
</html>